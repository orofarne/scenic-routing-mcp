+class ScenicPedestrianCost : public PedestrianCost {
+public:
+  explicit ScenicPedestrianCost(const Costing& costing_options);
+
+  Cost EdgeCost(const baldr::DirectedEdge* edge,
+                const baldr::GraphId& edgeid,
+                const graph_tile_ptr& tile,
+                const baldr::TimeInfo& time_info,
+                uint8_t& flow_sources) const override;
+
+private:
+  float sampleHeatmap(double lat, double lon) const noexcept;
+  void loadFromName(const std::string& name);
+
+  std::vector<uint8_t> heatmap_;
+  double min_lat_ = 0, min_lon_ = 0, max_lat_ = 0, max_lon_ = 0;
+  int width_ = 0, height_ = 0;
+  float scenic_weight_ = 0.8f; // passed via packed name; range [0, 1]
+
+  static constexpr char kSep = '\x1f'; // ASCII unit-separator; not in base64
+};
+
+void ScenicPedestrianCost::loadFromName(const std::string& name) {
+  // Format: "scenic_pedestrian\x1f<b64>\x1f<min_lat>\x1f<min_lon>\x1f<max_lat>\x1f<max_lon>\x1f<w>\x1f<h>\x1f<weight>"
+  static const std::string kPrefix = std::string("scenic_pedestrian") + kSep;
+  if (name.size() <= kPrefix.size() || name.compare(0, kPrefix.size(), kPrefix) != 0)
+    return;
+
+  // Split by kSep starting after the prefix
+  std::vector<std::string> parts;
+  size_t pos = kPrefix.size();
+  while (pos <= name.size()) {
+    size_t end = name.find(kSep, pos);
+    if (end == std::string::npos) end = name.size();
+    parts.push_back(name.substr(pos, end - pos));
+    pos = end + 1;
+  }
+  if (parts.size() < 7) return;
+
+  const std::string& b64 = parts[0];
+  double min_lat, min_lon, max_lat, max_lon;
+  int w, h;
+  try {
+    min_lat = std::stod(parts[1]); min_lon = std::stod(parts[2]);
+    max_lat = std::stod(parts[3]); max_lon = std::stod(parts[4]);
+    w = std::stoi(parts[5]);       h = std::stoi(parts[6]);
+  } catch (...) { return; }
+
+  auto decoded = scenic_base64_decode(b64);
+  if (decoded.size() != static_cast<size_t>(w) * static_cast<size_t>(h)) return;
+
+  heatmap_  = std::move(decoded);
+  min_lat_  = min_lat; min_lon_  = min_lon;
+  max_lat_  = max_lat; max_lon_  = max_lon;
+  width_    = w;       height_   = h;
+  if (parts.size() >= 8) {
+    try { scenic_weight_ = std::stof(parts[7]); } catch (...) {}
+  }
+}
+
+ScenicPedestrianCost::ScenicPedestrianCost(const Costing& costing_options)
+    : PedestrianCost(costing_options) {
+  loadFromName(costing_options.name());
+}
+
+float ScenicPedestrianCost::sampleHeatmap(double lat, double lon) const noexcept {
+  if (heatmap_.empty() || width_ <= 0 || height_ <= 0) return 0.0f;
+  if (lat < min_lat_ || lat > max_lat_ || lon < min_lon_ || lon > max_lon_) return 0.0f;
+  int x = static_cast<int>((lon - min_lon_) / (max_lon_ - min_lon_) * width_);
+  int y = static_cast<int>((max_lat_ - lat) / (max_lat_ - min_lat_) * height_);
+  x = std::max(0, std::min(width_ - 1, x));
+  y = std::max(0, std::min(height_ - 1, y));
+  return heatmap_[static_cast<size_t>(y) * width_ + x] / 255.0f;
+}
+
+Cost ScenicPedestrianCost::EdgeCost(const baldr::DirectedEdge* edge,
+                                    const baldr::GraphId& edgeid,
+                                    const graph_tile_ptr& tile,
+                                    const baldr::TimeInfo& time_info,
+                                    uint8_t& flow_sources) const {
+  Cost base = PedestrianCost::EdgeCost(edge, edgeid, tile, time_info, flow_sources);
+  if (heatmap_.empty() || !tile) return base;
+
+  // Sample heatmap along the full edge shape and average the heat values.
+  float h = 0.0f;
+  int n = 0;
+  const auto edgeinfo = tile->edgeinfo(edge);
+  for (const auto& ll : edgeinfo.shape()) {
+    h += sampleHeatmap(ll.lat(), ll.lng());
+    ++n;
+  }
+  if (n > 0) h /= n;
+  float factor = std::max(0.1f, 1.0f - scenic_weight_ * h);
+  return Cost{base.cost * factor, base.secs};
+}
+
+void ParseScenicPedestrianCostOptions(
+    const rapidjson::Document& doc,
+    const std::string& costing_options_key,
+    Costing* c,
+    google::protobuf::RepeatedPtrField<CodedDescription>& warnings) {
+  ParsePedestrianCostOptions(doc, costing_options_key, c, warnings);
+  c->set_type(Costing::scenic_pedestrian);
+  c->set_name("scenic_pedestrian");
+
+  rapidjson::Value dummy;
+  const auto& json = rapidjson::get_child(doc, costing_options_key.c_str(), dummy);
+
+  auto hdata   = rapidjson::get_optional<std::string>(json, "/heatmap_data");
+  auto min_lat = rapidjson::get_optional<double>(json, "/heatmap_min_lat");
+  auto min_lon = rapidjson::get_optional<double>(json, "/heatmap_min_lon");
+  auto max_lat = rapidjson::get_optional<double>(json, "/heatmap_max_lat");
+  auto max_lon = rapidjson::get_optional<double>(json, "/heatmap_max_lon");
+  auto w       = rapidjson::get_optional<int>(json, "/heatmap_width");
+  auto h       = rapidjson::get_optional<int>(json, "/heatmap_height");
+  auto sw      = rapidjson::get_optional<double>(json, "/heatmap_scenic_weight");
+
+  if (!hdata || hdata->empty() || !min_lat || !min_lon || !max_lat || !max_lon || !w || !h)
+    return;
+
+  auto decoded = scenic_base64_decode(*hdata);
+  if (decoded.size() != static_cast<size_t>(*w) * static_cast<size_t>(*h)) return;
+
+  // Pack heatmap metadata into the name field so both Loki and Thor can read
+  // it from the serialised Costing proto without needing shared state.
+  static const char sep = '\x1f';
+  std::string packed = std::string("scenic_pedestrian") + sep
+      + *hdata + sep
+      + std::to_string(*min_lat) + sep + std::to_string(*min_lon) + sep
+      + std::to_string(*max_lat) + sep + std::to_string(*max_lon) + sep
+      + std::to_string(*w)       + sep + std::to_string(*h)       + sep
+      + std::to_string(sw.value_or(0.8));
+  c->set_name(packed);
+}
+
+cost_ptr_t CreateScenicPedestrianCost(const Costing& costing_options) {
+  return std::make_shared<ScenicPedestrianCost>(costing_options);
+}
+
 cost_ptr_t CreatePedestrianCost(const Costing& costing_options) {
   return std::make_shared<PedestrianCost>(costing_options);
 }
