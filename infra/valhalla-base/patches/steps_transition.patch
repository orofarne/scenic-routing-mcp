+
+Cost ScenicPedestrianCost::TransitionCost(
+    const baldr::DirectedEdge* edge,
+    const baldr::NodeInfo* node,
+    const EdgeLabel& pred,
+    const graph_tile_ptr& tile,
+    const std::function<LimitedGraphReader()>& reader_getter) const {
+  Cost base = PedestrianCost::TransitionCost(edge, node, pred, tile, reader_getter);
+  if (heatmap_.empty() || base.cost <= 0.0f) return base;
+  const auto ll = node->latlng(tile->header()->base_ll());
+  float h = sampleHeatmap(ll.lat(), ll.lng());
+  float factor = std::max(0.1f, 1.0f - scenic_weight_ * h);
+  return Cost{base.cost * factor, base.secs};
 }
+
+float ScenicPedestrianCost::AStarCostFactor() const {
+  return std::max(0.1f, 1.0f - scenic_weight_) * PedestrianCost::AStarCostFactor();
